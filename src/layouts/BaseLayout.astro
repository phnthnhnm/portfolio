---
import BackgroundBlobs from "@components/BackgroundBlobs.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import LastUpdated from "@components/LastUpdated.astro";
import SEO from "@components/SEO.astro";
import StatusLink from "@components/StatusLink.astro";
import VisitorCounter from "@components/VisitorCounter.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  sourceFile?: string;
}

const { title, description, sourceFile } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ?? "Phan Thành Nam — Backend Engineer"}</title>
    <SEO title={title} description={description} />
  </head>
  <body>
    <BackgroundBlobs />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <div class="flex flex-col items-center gap-2 pb-8">
      {sourceFile && <LastUpdated filePath={sourceFile} />}
      <VisitorCounter />
      <StatusLink />
    </div>

    <button
      id="scroll-top-btn"
      class="pointer-events-none fixed right-5 bottom-20 z-40 flex h-10 w-10 items-center justify-center rounded-full border border-slate-700 bg-slate-900/90 text-slate-400 opacity-0 shadow-lg backdrop-blur transition-all duration-300 hover:border-slate-600 hover:text-slate-200 hover:bg-slate-800"
      aria-label="Scroll to top"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="m18 15-6-6-6 6" />
      </svg>
    </button>

    <script is:inline>
      const scrollBtn = document.getElementById("scroll-top-btn");
      if (scrollBtn) {
        window.addEventListener("scroll", () => {
          const show = window.scrollY > 500;
          scrollBtn.classList.toggle("opacity-0", !show);
          scrollBtn.classList.toggle("opacity-100", show);
          scrollBtn.classList.toggle("pointer-events-none", !show);
          scrollBtn.classList.toggle("pointer-events-auto", show);
        });
        scrollBtn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>
  </body>
</html>
