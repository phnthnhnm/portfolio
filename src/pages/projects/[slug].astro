---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content, headings } = await render(project);

// Filter to h2 and h3 only for TOC
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={`${project.data.title} — Phan Thành Nam`} description={project.data.description} sourceFile={`src/content/projects/${project.id}`}>
  <article class="section-container pt-24">
    <!-- Back link — defaults to /#projects, switches to /projects/ if referrer is the projects list page -->
    <a
      id="back-link"
      href="/#projects"
      class="mb-8 inline-flex items-center gap-2 text-sm text-slate-400 transition-colors hover:text-indigo-400"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="m12 19-7-7 7-7" />
        <path d="M19 12H5" />
      </svg>
      Back to Projects
    </a>

    <div class="lg:flex lg:gap-12">
      <!-- Sidebar: Table of Contents (desktop) -->
      {
        toc.length > 0 && (
          <aside class="hidden lg:block lg:w-56 lg:shrink-0">
            <div class="sticky top-24">
              <h4 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-500">
                On this page
              </h4>
              <nav id="toc-nav" class="border-l border-slate-800">
                <ul class="space-y-0.5">
                  {toc.map((h) => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        data-toc-link={h.slug}
                        class={`block border-l-2 -ml-px py-1.5 pr-3 text-sm text-slate-400 transition-colors hover:border-slate-500 hover:text-slate-200 ${
                          h.depth === 3 ? "pl-6" : "pl-3"
                        }`}
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </aside>
        )
      }

      <!-- Main content -->
      <div class="min-w-0 flex-1">
        <!-- Header -->
        <header class="mb-12">
          <h1 class="mb-4 text-4xl font-bold tracking-tight sm:text-5xl">
            <span class="text-gradient">{project.data.title}</span>
          </h1>
          <p class="mb-6 max-w-2xl text-lg leading-relaxed text-slate-400">
            {project.data.description}
          </p>

          <div class="mb-6 flex flex-wrap gap-2">
            {project.data.techStack.map((tech) => (
              <span class="badge">{tech}</span>
            ))}
          </div>

          <div class="flex flex-wrap gap-4">
            {project.data.githubUrl && (
              <a
                href={project.data.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-lg border border-slate-700 px-5 py-2.5 font-medium text-slate-300 transition-colors hover:border-indigo-500 hover:text-indigo-400"
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                View Source
              </a>
            )}
            {project.data.liveUrl && (
              <a
                href={project.data.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-lg bg-indigo-500 px-5 py-2.5 font-medium text-white transition-colors hover:bg-indigo-400"
              >
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 3h6v6" />
                  <path d="M10 14 21 3" />
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                </svg>
                Live Demo
              </a>
            )}
          </div>
        </header>

        <!-- Article body -->
        <div class="prose prose-invert prose-slate max-w-none
          prose-headings:scroll-mt-24 prose-headings:text-slate-100
          prose-h2:mt-12 prose-h2:mb-4 prose-h2:text-2xl prose-h2:font-bold prose-h2:tracking-tight
          prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-xl prose-h3:font-semibold
          prose-p:leading-relaxed prose-p:text-slate-400
          prose-li:text-slate-400 prose-li:leading-relaxed
          prose-code:rounded prose-code:bg-slate-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm prose-code:text-indigo-400 prose-code:before:content-none prose-code:after:content-none
          prose-pre:border prose-pre:border-slate-800 prose-pre:bg-slate-950
          prose-a:text-indigo-400 prose-a:no-underline hover:prose-a:underline
          prose-strong:text-slate-200
          prose-table:w-full prose-table:overflow-hidden prose-table:rounded-lg prose-table:border prose-table:border-slate-800
          prose-th:border-b prose-th:border-slate-800 prose-th:bg-slate-900/50 prose-th:px-4 prose-th:py-2.5 prose-th:text-left prose-th:text-sm prose-th:font-semibold prose-th:text-slate-300
          prose-td:border-b prose-td:border-slate-800/50 prose-td:px-4 prose-td:py-2.5 prose-td:text-sm prose-td:text-slate-400
          prose-hr:border-slate-800
          prose-img:rounded-xl
        ">
          <Content />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<script is:inline>
  // If the user came from the projects list page, point the back link there instead of /#projects
  const backLink = document.getElementById("back-link");
  if (backLink && document.referrer) {
    try {
      const refUrl = new URL(document.referrer);
      if (refUrl.pathname === "/projects/" || refUrl.pathname === "/projects") {
        backLink.href = "/projects/";
      }
    } catch {}
  }
</script>

<script is:inline>
  // Highlight active TOC link on scroll
  const tocLinks = document.querySelectorAll("[data-toc-link]");
  if (tocLinks.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => {
              const slug = link.getAttribute("data-toc-link");
              if (slug === entry.target.id) {
                link.classList.add("!border-indigo-400", "!text-indigo-300");
              } else {
                link.classList.remove("!border-indigo-400", "!text-indigo-300");
              }
            });
          }
        }
      },
      { rootMargin: "-80px 0px -70% 0px" }
    );

    for (const link of tocLinks) {
      const slug = link.getAttribute("data-toc-link");
      const target = document.getElementById(slug ?? "");
      if (target) observer.observe(target);
    }
  }
</script>

<script>
  // Add copy buttons to code blocks
  document.querySelectorAll("pre.astro-code").forEach((pre) => {
    if (!pre.parentNode) return;
    const wrapper = document.createElement("div");
    wrapper.className = "code-block-wrapper";
    pre.parentNode.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const btn = document.createElement("button");
    btn.className = "copy-code-btn";
    btn.innerHTML = '<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" /><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" /></svg>';
    btn.title = "Copy";
    wrapper.appendChild(btn);

    btn.addEventListener("click", async () => {
      const text = pre.textContent || "";
      await navigator.clipboard.writeText(text);
      btn.innerHTML = '<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>';
      btn.classList.add("copied");
      setTimeout(() => {
        btn.innerHTML = '<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" /><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" /></svg>';
        btn.classList.remove("copied");
      }, 2000);
    });
  });
</script>

<script src="/mermaid-viewer.js" is:inline></script>

<style is:global>
  /* Mermaid diagram viewer — zoom/pan/overlay */
  .mermaid-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid #1e293b;
    background: #0f172a;
    cursor: zoom-in;
    min-height: 200px;
  }
  .mermaid-wrapper .mermaid {
    margin: 0;
    padding: 1.5rem;
    transition: transform 0.1s ease-out;
  }
  .mermaid-wrapper.dragging {
    cursor: grabbing;
  }
  .mermaid-expand-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    z-index: 2;
    padding: 0.375rem;
    border-radius: 0.5rem;
    background: #1e293b;
    border: 1px solid #334155;
    color: #94a3b8;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mermaid-expand-btn:hover {
    color: #e2e8f0;
    background: #334155;
  }

  /* Fullscreen overlay */
  .mermaid-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
  }
  .mermaid-overlay.active {
    display: block;
  }
  .mermaid-overlay-bg {
    position: absolute;
    inset: 0;
    background: rgba(2, 6, 23, 0.92);
    backdrop-filter: blur(4px);
  }
  .mermaid-overlay-content {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mermaid-overlay-close {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 101;
    padding: 0.5rem;
    border-radius: 0.5rem;
    background: #1e293b;
    border: 1px solid #334155;
    color: #94a3b8;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }
  .mermaid-overlay-close:hover {
    color: #fff;
    background: #ef4444;
    border-color: #ef4444;
  }
  .mermaid-overlay-controls {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 101;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    border-radius: 9999px;
    background: #1e293b;
    border: 1px solid #334155;
  }
  .mermaid-overlay-controls button {
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: none;
    background: transparent;
    color: #cbd5e1;
    cursor: pointer;
    font-size: 1.125rem;
    font-weight: 600;
    transition: background 0.15s;
  }
  .mermaid-overlay-controls button:hover {
    background: #334155;
    color: #fff;
  }
  .mermaid-zoom-level {
    min-width: 3rem;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 500;
    color: #94a3b8;
  }
  .mermaid-overlay-stage {
    cursor: grab;
    max-width: 95vw;
    max-height: 85vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mermaid-overlay-stage.dragging {
    cursor: grabbing;
  }
  .mermaid-overlay-stage svg {
    max-height: 85vh;
    width: auto;
    transition: transform 0.05s ease-out;
  }
</style>
