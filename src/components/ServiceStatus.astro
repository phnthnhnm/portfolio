---
---

<div id="service-status" class="section-container">
  <h2 class="section-title">
    <span class="text-gradient">Service Status</span>
  </h2>

  <!-- Summary banner -->
  <div
    id="status-summary"
    class="card mb-6 flex items-center gap-3 border-l-4"
    data-status="checking"
  >
    <div id="status-summary-icon" class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-slate-800">
      <svg class="h-4 w-4 animate-spin text-slate-500" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </div>
    <div>
      <p id="status-summary-text" class="font-medium text-slate-300">Checking services&hellip;</p>
      <p id="status-summary-detail" class="text-sm text-slate-500">Please wait</p>
    </div>
  </div>

  <!-- Controls -->
  <div class="mb-6 flex items-center justify-between">
    <p id="status-last-checked" class="text-sm text-slate-500"></p>
    <button
      id="status-refresh-btn"
      class="inline-flex items-center gap-2 rounded-lg border border-slate-700 px-4 py-2 text-sm font-medium text-slate-300 transition-colors hover:border-slate-500 hover:text-white"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" />
      </svg>
      Refresh
    </button>
  </div>

  <!-- Service cards -->
  <div id="status-services" class="space-y-3">
  </div>
</div>

<script is:inline>
  (() => {
    var SERVICES = [
      {
        id: "contact",
        name: "Contact API",
        url: "/api/contact",
        description: "Contact form endpoint — email delivery via Resend",
        method: "HEAD",
      },
      {
        id: "counter",
        name: "Visitor Counter",
        url: "/api/counter",
        description: "Page view counter backed by Cloudflare KV",
        method: "GET",
      },
      {
        id: "github",
        name: "GitHub",
        url: "https://github.com",
        description: "Source code hosting",
        cors: "no-cors",
      },
      {
        id: "resume",
        name: "Resume",
        url: "https://rxresu.me",
        description: "Public resume hosted on Reactive Resume",
        cors: "no-cors",
      },
    ];

    var TIMEOUT_MS = 5000;
    var SLOW_THRESHOLD_MS = 1500;
    var REFRESH_INTERVAL_S = 60;

    var container = document.getElementById("service-status");
    if (!container) return;

    var summaryEl = document.getElementById("status-summary");
    var summaryIconEl = document.getElementById("status-summary-icon");
    var summaryTextEl = document.getElementById("status-summary-text");
    var summaryDetailEl = document.getElementById("status-summary-detail");
    var lastCheckedEl = document.getElementById("status-last-checked");
    var refreshBtn = document.getElementById("status-refresh-btn");
    var servicesEl = document.getElementById("status-services");

    function statusIcon(status) {
      switch (status) {
        case "up":
          return '<svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';
        case "slow":
          return '<svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L7.432 11.376M12 15.75h.007v.008H12v-.008z" /></svg>';
        case "down":
          return '<svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>';
        case "checking":
          return '<svg class="h-4 w-4 animate-spin text-slate-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
      }
    }

    function latencyText(latency) {
      if (latency === null) return "--";
      if (latency < 1000) return Math.round(latency) + "ms";
      return (latency / 1000).toFixed(1) + "s";
    }

    function latencyColor(latency) {
      if (latency === null) return "text-red-400";
      return latency > SLOW_THRESHOLD_MS ? "text-amber-400" : "text-emerald-400";
    }

    async function checkService(svc) {
      var controller = new AbortController();
      var timeout = setTimeout(function () { controller.abort(); }, TIMEOUT_MS);

      var start = performance.now();
      try {
        var init = { signal: controller.signal };
        if (svc.cors === "no-cors") {
          init.mode = "no-cors";
        } else {
          init.method = svc.method || "GET";
        }
        await fetch(svc.url, init);
        var latency = performance.now() - start;
        clearTimeout(timeout);
        return {
          id: svc.id,
          name: svc.name,
          url: svc.url,
          status: latency > SLOW_THRESHOLD_MS ? "slow" : "up",
          latency: latency,
        };
      } catch (err) {
        clearTimeout(timeout);
        var isTimeout = err instanceof DOMException && err.name === "AbortError";
        return {
          id: svc.id,
          name: svc.name,
          url: svc.url,
          status: "down",
          latency: null,
          error: isTimeout ? "Request timed out" : err instanceof Error ? err.message : String(err),
        };
      }
    }

    // Pre-compute descriptions lookup
    var descriptions = {};
    SERVICES.forEach(function (s) { descriptions[s.id] = s.description; });

    function renderChecking() {
      servicesEl.innerHTML = SERVICES.map(function (s) {
        return (
          '<div class="card flex items-start gap-4 opacity-60">' +
          '<div class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center">' +
          statusIcon("checking") +
          "</div>" +
          '<div class="min-w-0 flex-1">' +
          '<div class="flex flex-wrap items-center justify-between gap-x-4 gap-y-1">' +
          '<h3 class="font-medium text-slate-200">' + s.name + "</h3>" +
          '<div class="flex items-center gap-3">' +
          '<code class="text-xs text-slate-500">' + s.url + "</code>" +
          '<span class="text-xs tabular-nums text-slate-500">--</span>' +
          "</div>" +
          "</div>" +
          '<p class="text-sm text-slate-500">' + (descriptions[s.id] || "") + "</p>" +
          "</div>" +
          "</div>"
        );
      }).join("");
    }

    function renderResults(results) {
      servicesEl.innerHTML = results.map(function (r) {
        return (
          '<div class="card flex items-start gap-4">' +
          '<div class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center">' +
          statusIcon(r.status) +
          "</div>" +
          '<div class="min-w-0 flex-1">' +
          '<div class="flex flex-wrap items-center justify-between gap-x-4 gap-y-1">' +
          '<h3 class="font-medium text-slate-200">' + r.name + "</h3>" +
          '<div class="flex items-center gap-3">' +
          '<code class="text-xs text-slate-500">' + r.url + "</code>" +
          '<span class="text-xs tabular-nums ' + latencyColor(r.latency) + '">' + latencyText(r.latency) + "</span>" +
          "</div>" +
          "</div>" +
          '<p class="text-sm text-slate-500">' + (r.error ? '<span class="text-red-400">' + r.error + "</span>" : descriptions[r.id] || "") + "</p>" +
          "</div>" +
          "</div>"
        );
      }).join("");

      var down = results.filter(function (r) { return r.status === "down"; }).length;
      var slow = results.filter(function (r) { return r.status === "slow"; }).length;

      var status, icon, text, detail;

      if (down > 0) {
        status = "down";
        icon = statusIcon("down");
        text = down + " service" + (down > 1 ? "s" : "") + " down";
        var parts = [];
        if (down) parts.push(down + " unreachable");
        if (slow) parts.push(slow + " degraded");
        detail = parts.join(", ");
      } else if (slow > 0) {
        status = "slow";
        icon = statusIcon("slow");
        text = slow + " service" + (slow > 1 ? "s" : "") + " degraded";
        detail = "Elevated response times";
      } else {
        status = "up";
        icon = statusIcon("up");
        text = "All systems operational";
        detail = "Everything is running smoothly";
      }

      // Swap border-l color
      summaryEl.dataset.status = status;
      summaryEl.className = summaryEl.className.replace(/border-l-(slate|red|amber|emerald)-\d+/, "");
      var borderColor = {
        up: "border-l-emerald-500",
        slow: "border-l-amber-500",
        down: "border-l-red-500",
      }[status];
      if (borderColor) summaryEl.classList.add(borderColor);

      summaryIconEl.innerHTML = icon;
      summaryTextEl.textContent = text;
      summaryDetailEl.textContent = detail;
    }

    var autoInterval;

    function updateTimestamp() {
      lastCheckedEl.textContent = "Last checked: " + new Date().toLocaleTimeString() + "  ·  Auto-refreshes every " + REFRESH_INTERVAL_S + "s";
    }

    async function checkAll() {
      renderChecking();
      var results = await Promise.all(SERVICES.map(checkService));
      renderResults(results);
      updateTimestamp();
    }

    function resetInterval() {
      clearInterval(autoInterval);
      autoInterval = setInterval(checkAll, REFRESH_INTERVAL_S * 1000);
    }

    refreshBtn.addEventListener("click", function () {
      checkAll();
      resetInterval();
    });

    // Kick off
    autoInterval = setInterval(checkAll, REFRESH_INTERVAL_S * 1000);
    checkAll();
  })();
</script>
