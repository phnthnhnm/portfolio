<section id="about" class="section-container">
  <h2 class="section-title">
    <span class="text-gradient">About</span>
  </h2>

  <div class="grid gap-12 lg:grid-cols-5">
    <div class="lg:col-span-3">
      <p class="mb-4 text-lg leading-relaxed text-slate-400">
        I'm a backend engineer with a passion for designing and building
        systems that are scalable, maintainable, and reliable. My focus
        is on creating clean APIs, robust data pipelines, and
        well-architected distributed systems.
      </p>
      <p class="mb-4 text-lg leading-relaxed text-slate-400">
        With experience across the .NET ecosystem, cloud infrastructure,
        and database design, I enjoy tackling complex problems — from
        optimizing query performance to designing event-driven
        microservices.
      </p>
      <p class="text-lg leading-relaxed text-slate-400">
        When I'm not writing code, you'll find me exploring new
        technologies, contributing to open-source projects, or
        reading about system design and software architecture.
      </p>
    </div>

    <div class="lg:col-span-2">
      <div class="card space-y-4">
        <h3 class="text-lg font-semibold">Quick Facts</h3>
        <ul class="space-y-3 text-sm text-slate-400">
          <li class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </span>
            Based in Vietnam
          </li>
          <li class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
                <path d="M2 9v11a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9" />
                <path d="M2 9h20" />
                <path d="M2 9l9.687 5.284a1 1 0 0 0 .626 0L22 9" />
              </svg>
            </span>
            Backend Engineering
          </li>
          <li class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z" />
              </svg>
            </span>
            .NET, C#, Go, Python
          </li>
          <li class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="8" x="2" y="2" rx="2" />
                <rect width="20" height="8" x="2" y="14" rx="2" />
                <line x1="6" y1="6" x2="6.01" y2="6" />
                <line x1="6" y1="18" x2="6.01" y2="18" />
              </svg>
            </span>
            PostgreSQL, Redis, RabbitMQ
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
