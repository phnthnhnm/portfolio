---
import { getCollection } from "astro:content";

const allProjects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);

// Only show iras-rag and evdms on the home page
const featuredSlugs = ["iras-rag", "evdms"];
const projects = allProjects.filter((p) => featuredSlugs.includes(p.id.replace(/\.md$/, "")));

function slug(id: string) {
  return id.replace(/\.md$/, "");
}
---

<section id="projects" class="section-container">
  <h2 class="section-title">
    <span class="text-gradient">Projects</span>
  </h2>

  <div class="grid gap-6 md:grid-cols-2">
    {projects.map((project) => (
      <div class="card group flex flex-col">
        <div class="mb-4 flex items-start justify-between">
          <a
            href={`/projects/${slug(project.id)}/`}
            class="text-xl font-semibold transition-colors hover:text-indigo-400"
          >
            {project.data.title}
          </a>
          <div class="flex gap-2">
            {project.data.githubUrl && (
              <a
                href={project.data.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-500 transition-colors hover:text-slate-300"
                aria-label={`${project.data.title} GitHub`}
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
            )}
            {project.data.liveUrl && (
              <a
                href={project.data.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-500 transition-colors hover:text-slate-300"
                aria-label={`${project.data.title} live demo`}
              >
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 3h6v6" />
                  <path d="M10 14 21 3" />
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                </svg>
              </a>
            )}
          </div>
        </div>

        <p class="mb-4 flex-1 leading-relaxed text-slate-400">
          {project.data.description}
        </p>

        <!-- Tech stack tags -->
        <div class="mb-4 flex flex-wrap gap-2">
          {project.data.techStack.map((tech) => (
            <span class="badge">{tech}</span>
          ))}
        </div>

        <!-- View details link -->
        <a
          href={`/projects/${slug(project.id)}/`}
          class="inline-flex items-center gap-1 text-sm font-medium text-indigo-400 transition-colors hover:text-indigo-300"
        >
          View Details
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    ))}
  </div>

  <div class="mt-10 text-center">
    <a
      href="/projects/"
      class="inline-flex items-center gap-2 rounded-lg border border-slate-700 px-6 py-3 font-medium text-slate-300 transition-colors hover:border-indigo-500 hover:text-indigo-400"
    >
      View all {allProjects.length} projects
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    </a>
  </div>
</section>
