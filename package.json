{
  "name": "portfolio",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "dev:full": "astro build && wrangler pages dev dist",
    "build": "astro build",
    "build:ci": "pnpm format:check && pnpm lint && pnpm test && pnpm build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lighthouse": "astro build && node scripts/lighthouse.mjs",
    "lighthouse:ci": "astro build && node scripts/lighthouse.mjs --ci",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/preact": "^5.1.5",
    "@tailwindcss/typography": "^0.5.20",
    "astro": "^6.4.8",
    "preact": "^10.29.2",
    "tailwindcss": "^4.3.1",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.1",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.0.0",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}
